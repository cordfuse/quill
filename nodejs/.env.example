# Copy to .env.local and fill in. .env.local is gitignored.

# ─── Required ────────────────────────────────────────────────────────────────

# JWT secret for signing device-auth tokens. Any random ≥32-char string.
# Generate: openssl rand -base64 32
JWT_SECRET=

# Provider API key — only the selected provider's key needs to be set.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# COHERE_API_KEY=
# PERPLEXITY_API_KEY=
# AI21_API_KEY=
# AWS_ACCESS_KEY_ID= + AWS_SECRET_ACCESS_KEY= + AWS_REGION=    # for bedrock

# ─── Optional (defaults shown) ───────────────────────────────────────────────

# Which provider to use. One of: anthropic | openai | gemini | groq | mistral |
#                                 cohere | perplexity | bedrock | ai21
# QUILL_PROVIDER=anthropic

# Provider-specific model ID. token.js's built-in list tops out at Claude
# 3.7-sonnet for Anthropic; the Claude 4.x family (Opus 4.7, Sonnet 4.6,
# Haiku 4.5) is registered explicitly via extendModelList in
# lib/server/ai-tools.ts. Add more models there as needed.
# QUILL_MODEL=claude-sonnet-4-6

# Baseline system prompt the model sees. Override to specialize the assistant.
# QUILL_SYSTEM_PROMPT="You are a helpful AI assistant."
